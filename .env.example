# Supabase (production persistence + auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth: set true only for local dev without login
AUTH_DISABLED=false

# AI Agent (Layer 6)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Email (Layer 4) — Resend
RESEND_API_KEY=re_...
EMAIL_FROM=Carly Bryant <coordination@yourdomain.com>
ALERT_EMAIL=carly.bryant@kw.com

# Vercel Cron auth
CRON_SECRET=generate-a-random-secret
REVIEW_SLA_HOURS=24

# Inbound email webhook (Resend/Postmark/etc.)
INBOUND_EMAIL_WEBHOOK_SECRET=generate-a-random-secret

# ElevenLabs ConvAI (chat + voice assistant)
ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_LLM=gemini-2.5-flash

# Agent webhook tools (ElevenLabs → /api/agent/tools/*)
AGENT_WEBHOOK_SECRET=generate-a-random-secret
AGENT_WEBHOOK_BASE_URL=https://lc-tc-platform.vercel.app

# Integrations (optional — stubs used when unset)
MLS_API_URL=
MLS_API_KEY=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_USER_ID=
SHOWINGTIME_API_KEY=
